{
	"$schema": "https://json.schemastore.org/nest-cli",
	"collection": "@nestjs/schematics",
	"sourceRoot": "src",
	"compilerOptions": {
		"deleteOutDir": true,
		"assets": [
			{
				"include": "../prisma/__generated__",
				"outDir": "dist/prisma",
				"watchAssets": true
			}
		],
		"watchAssets": true
	}
}
